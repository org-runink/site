{
  "name": "hugo-sassify-theme",
  "version": "1.0.0",
  "description": "A modern Hugo theme for SaaS websites",
  "author": "Chaoming Li",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npx tailwindcss -i themes/hugo-saasify-theme/assets/css/main.css -o static/css/style.css --watch\" \"hugo server -D\"",
    "build": "tailwindcss -i themes/hugo-saasify-theme/assets/css/main.css -o static/css/style.css --minify",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "autoprefixer": "^10.4.16",
    "babel-jest": "^30.4.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.3.5"
  },
  "dependencies": {
    "hugo-bin": "^0.149.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "hugo-bin",
      "unrs-resolver",
      "@unrs/resolver-binding-linux-x64-gnu"
    ]
  },
  "main": "postcss.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/org-runink/site.git"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/org-runink/site/issues"
  },
  "homepage": "https://github.com/org-runink/site#readme"
}
